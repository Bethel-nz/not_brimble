{
  "admin": {
    "listen": "0.0.0.0:2019"
  },
  "apps": {
    "http": {
      "servers": {
        "srv0": {
          "listen": [":80"],
          "routes": [
            {
              "match": [{ "host": ["localhost", "127.0.0.1"], "path": ["/api/*"] }],
              "handle": [
                { "handler": "rewrite", "strip_path_prefix": "/api" },
                { "handler": "reverse_proxy", "upstreams": [{ "dial": "api:8080" }] }
              ]
            },
            {
              "match": [{ "host": ["localhost", "127.0.0.1"] }],
              "handle": [
                { "handler": "reverse_proxy", "upstreams": [{ "dial": "web:80" }] }
              ]
            }
          ]
        }
      }
    }
  }
}
